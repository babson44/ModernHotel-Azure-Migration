@model ModernHotel.Core.DTOs.CreateGuestDto
@{
    ViewData["Title"] = "Add Guest";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card stat-card">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">First Name</label>
                            <input asp-for="FirstName" class="form-control" placeholder="e.g. James" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Last Name</label>
                            <input asp-for="LastName" class="form-control" placeholder="e.g. Mitchell" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Email</label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="guest@example.com" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Phone</label>
                            <input asp-for="Phone" class="form-control" placeholder="+1-555-0100" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Nationality <span class="text-muted fw-normal">(optional)</span></label>
                            <input asp-for="Nationality" class="form-control" placeholder="e.g. American" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Address <span class="text-muted fw-normal">(optional)</span></label>
                            <input asp-for="Address" class="form-control" placeholder="123 Main St, City, Country" />
                        </div>
                        <div class="col-12 d-flex gap-2 mt-2">
                            <button type="submit" class="btn btn-warning text-white">
                                <i class="bi bi-person-check me-1"></i>Add Guest
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
