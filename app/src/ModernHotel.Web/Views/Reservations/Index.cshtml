@model List<ModernHotel.Core.DTOs.ReservationDto>
@{
    ViewData["Title"] = "Reservations";
    var current = ViewBag.CurrentStatus as string;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="btn-group btn-group-sm">
        <a asp-action="Index" class="btn @(current == null ? "btn-dark" : "btn-outline-secondary")">All</a>
        <a asp-action="Index" asp-route-status="CheckedIn" class="btn @(current == "CheckedIn" ? "btn-success" : "btn-outline-secondary")">In-House</a>
        <a asp-action="Index" asp-route-status="Confirmed" class="btn @(current == "Confirmed" ? "btn-primary" : "btn-outline-secondary")">Arriving</a>
        <a asp-action="Index" asp-route-status="Pending" class="btn @(current == "Pending" ? "btn-warning" : "btn-outline-secondary")">Pending</a>
        <a asp-action="Index" asp-route-status="CheckedOut" class="btn @(current == "CheckedOut" ? "btn-secondary" : "btn-outline-secondary")">Checked Out</a>
    </div>
    <a asp-action="Create" class="btn btn-sm btn-warning text-white">
        <i class="bi bi-plus-lg me-1"></i>New Reservation
    </a>
</div>

<div class="card stat-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Guest</th>
                        <th>Room</th>
                        <th>Check In</th>
                        <th>Check Out</th>
                        <th>Nights</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td class="text-muted small">@r.Id</td>
                            <td>
                                <div class="fw-semibold small">@r.GuestName</div>
                                <div class="text-muted" style="font-size:0.7rem;">@r.GuestEmail</div>
                            </td>
                            <td>
                                <span class="fw-semibold">@r.RoomNumber</span>
                                <span class="text-muted small ms-1">@r.RoomTypeName</span>
                            </td>
                            <td class="small">@r.CheckInDate.ToString("MMM d, yyyy")</td>
                            <td class="small">@r.CheckOutDate.ToString("MMM d, yyyy")</td>
                            <td class="small text-center">@r.Nights</td>
                            <td class="small fw-semibold">$@r.TotalAmount.ToString("N2")</td>
                            <td>
                                @{
                                    var badgeClass = r.Status.ToString() switch
                                    {
                                        "CheckedIn" => "badge-checkedin",
                                        "CheckedOut" => "badge-checkedout",
                                        "Confirmed" => "badge-confirmed",
                                        "Pending" => "badge-pending",
                                        "Cancelled" => "badge-cancelled",
                                        "NoShow" => "badge-noshow",
                                        _ => "badge-secondary"
                                    };
                                }
                                <span class="status-badge @badgeClass">@r.StatusName</span>
                            </td>
                            <td>
                                @if (r.Status.ToString() is "Confirmed" or "Pending")
                                {
                                    <form asp-action="CheckIn" asp-route-id="@r.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-xs btn-success" style="font-size:0.7rem;padding:2px 8px;"
                                                onclick="return confirm('Check in @r.GuestName?')">
                                            <i class="bi bi-box-arrow-in-right"></i> Check In
                                        </button>
                                    </form>
                                }
                                @if (r.Status.ToString() == "CheckedIn")
                                {
                                    <form asp-action="CheckOut" asp-route-id="@r.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-xs btn-secondary" style="font-size:0.7rem;padding:2px 8px;"
                                                onclick="return confirm('Check out @r.GuestName?')">
                                            <i class="bi bi-box-arrow-right"></i> Check Out
                                        </button>
                                    </form>
                                }
                                @if (r.Status.ToString() is "Confirmed" or "Pending")
                                {
                                    <form asp-action="Cancel" asp-route-id="@r.Id" method="post" class="d-inline ms-1">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-xs btn-outline-danger" style="font-size:0.7rem;padding:2px 8px;"
                                                onclick="return confirm('Cancel this reservation?')">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
<div class="text-muted small mt-2">@Model.Count reservation(s) shown</div>
