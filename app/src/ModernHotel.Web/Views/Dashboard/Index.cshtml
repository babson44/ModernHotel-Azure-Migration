@model ModernHotel.Core.DTOs.DashboardSummaryDto
@{
    ViewData["Title"] = "Dashboard";
}

@if (Model == null)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle me-2"></i>
        Could not connect to the hotel API. Make sure the API service is running.
    </div>
}
else
{
    <!-- KPI Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-xl-3">
            <div class="card stat-card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="icon-box bg-primary bg-opacity-10 text-primary"><i class="bi bi-people-fill"></i></div>
                    <div>
                        <div class="fw-bold fs-4">@Model.TotalGuests</div>
                        <div class="text-muted small">Total Guests</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card stat-card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="icon-box bg-success bg-opacity-10 text-success"><i class="bi bi-door-open-fill"></i></div>
                    <div>
                        <div class="fw-bold fs-4">@Model.AvailableRooms <span class="fs-6 text-muted">/ @Model.TotalRooms</span></div>
                        <div class="text-muted small">Rooms Available</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card stat-card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="icon-box bg-warning bg-opacity-10 text-warning"><i class="bi bi-house-fill"></i></div>
                    <div>
                        <div class="fw-bold fs-4">@Model.CheckedInGuests</div>
                        <div class="text-muted small">In-House Guests</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card stat-card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="icon-box" style="background:rgba(201,168,76,0.12); color:#c9a84c;"><i class="bi bi-currency-dollar"></i></div>
                    <div>
                        <div class="fw-bold fs-4">$@Model.RevenueThisMonth.ToString("N0")</div>
                        <div class="text-muted small">Revenue This Month</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Occupancy + Today Summary -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card stat-card h-100">
                <div class="card-body text-center py-4">
                    <div class="display-4 fw-bold" style="color:#c9a84c;">@Model.OccupancyRate<span class="fs-3">%</span></div>
                    <div class="text-muted">Occupancy Rate</div>
                    <div class="progress mt-3" style="height:8px;">
                        <div class="progress-bar" style="width:@Model.OccupancyRate%; background:#c9a84c;"></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card stat-card h-100">
                <div class="card-body">
                    <h6 class="fw-semibold mb-3">Today's Activity</h6>
                    <div class="row text-center">
                        <div class="col-4 border-end">
                            <div class="fw-bold fs-3 text-success">@Model.ArrivalsToday</div>
                            <div class="text-muted small"><i class="bi bi-box-arrow-in-right me-1"></i>Arrivals</div>
                        </div>
                        <div class="col-4 border-end">
                            <div class="fw-bold fs-3 text-danger">@Model.DeparturesToday</div>
                            <div class="text-muted small"><i class="bi bi-box-arrow-right me-1"></i>Departures</div>
                        </div>
                        <div class="col-4">
                            <div class="fw-bold fs-3 text-primary">@Model.ActiveReservations</div>
                            <div class="text-muted small"><i class="bi bi-calendar-check me-1"></i>Active Bookings</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="card stat-card">
        <div class="card-body">
            <h6 class="fw-semibold mb-3">Quick Actions</h6>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-controller="Reservations" asp-action="Index" asp-route-status="CheckedIn"
                   class="btn btn-sm btn-outline-success"><i class="bi bi-house-fill me-1"></i>View In-House</a>
                <a asp-controller="Reservations" asp-action="Index" asp-route-status="Confirmed"
                   class="btn btn-sm btn-outline-primary"><i class="bi bi-clock me-1"></i>Today's Arrivals</a>
                <a asp-controller="Reservations" asp-action="Create"
                   class="btn btn-sm btn-warning text-white"><i class="bi bi-plus-lg me-1"></i>New Reservation</a>
                <a asp-controller="Guests" asp-action="Create"
                   class="btn btn-sm btn-outline-secondary"><i class="bi bi-person-plus me-1"></i>Add Guest</a>
            </div>
        </div>
    </div>
}
